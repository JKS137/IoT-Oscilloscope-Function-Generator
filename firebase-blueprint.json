{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "SavedWaveform": {
      "title": "SavedWaveform",
      "description": "A snapshot of a captured waveform",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "points": { "type": "array" },
        "settings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "points"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/waveforms/{waveformId}": {
      "schema": "SavedWaveform",
      "description": "Stored waveform captures"
    }
  }
}
